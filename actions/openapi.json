{
  "openapi": "3.0.3",
  "info": {
    "title": "Partner Intake OS GPT Action API",
    "version": "0.1.0",
    "description": "Safe GPT-facing Action schema for Partner Intake OS. Exposes only health and partner workflow endpoints. Does not expose Tally webhooks, admin endpoints, raw storage endpoints, or private sync routes."
  },
  "servers": [
    {
      "url": "https://YOUR_VERCEL_DOMAIN.vercel.app",
      "description": "Live Vercel deployment placeholder"
    }
  ],
  "security": [
    {
      "PartnerIntakeBearerAuth": []
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Check Partner Intake OS API health",
        "description": "Returns service health for the Partner Intake OS API. This endpoint is safe to expose to GPT Actions and does not return secrets or PII.",
        "operationId": "checkHealth",
        "tags": [
          "Partner Intake OS"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Health response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/partners/classify": {
      "post": {
        "summary": "Classify partner intake",
        "description": "Classifies a normalized or manual partner intake into partner profile, scorecard, tier, onboarding path, risk flags, and next action. Keep responses compliance-safe and review-oriented.",
        "operationId": "classifyPartnerIntake",
        "tags": [
          "Partner Intake OS"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClassifyPartnerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "405": {
            "description": "Method not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "PartnerIntakeBearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClassifyPartnerRequest"
              },
              "examples": {
                "cpaBookkeeper": {
                  "summary": "CPA/bookkeeper referral partner",
                  "value": {
                    "context": "manual_review",
                    "intake": {
                      "first_name": "Dana",
                      "last_name": "Cole",
                      "email": "dana@example.com",
                      "company": "Cole Advisory",
                      "partner_type_claimed": "CPA/bookkeeper",
                      "audience": "contractors and local service businesses",
                      "notes": "Existing clients ask about working capital options."
                    }
                  }
                },
                "highRiskLeadSeller": {
                  "summary": "High-risk lead seller",
                  "value": {
                    "context": "manual_review",
                    "intake": {
                      "first_name": "Blake",
                      "last_name": "Stone",
                      "email": "blake@example.com",
                      "company": "Lead Rocket Pros",
                      "partner_type_claimed": "Lead seller",
                      "audience": "Purchased SMB lead lists",
                      "notes": "Can sell exclusive leads and says everyone qualifies. Wants fast payout before verification."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/partners/recommend-resources": {
      "post": {
        "summary": "Recommend partner resources",
        "description": "Returns recommended resources based on partner type, audience, and tier. Use this after classification or when manually planning partner activation.",
        "operationId": "recommendPartnerResources",
        "tags": [
          "Partner Intake OS"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceRecommendationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "405": {
            "description": "Method not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "PartnerIntakeBearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResourceRecommendationRequest"
              }
            }
          }
        }
      }
    },
    "/api/partners/generate-onboarding-plan": {
      "post": {
        "summary": "Generate partner onboarding plan",
        "description": "Returns first 24 hours, first 7 days, first 30 days, required assets, owner, and next action for a partner.",
        "operationId": "generatePartnerOnboardingPlan",
        "tags": [
          "Partner Intake OS"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnboardingPlanResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "405": {
            "description": "Method not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "PartnerIntakeBearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OnboardingPlanRequest"
              }
            }
          }
        }
      }
    },
    "/api/partners/generate-campaign-kit": {
      "post": {
        "summary": "Generate partner campaign kit",
        "description": "Returns campaign concept, CTA, channel suggestions, tracking notes, and copy angle. Copy must avoid guaranteed approvals, guaranteed funding, fake certainty, and deceptive urgency.",
        "operationId": "generatePartnerCampaignKit",
        "tags": [
          "Partner Intake OS"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignKitResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "405": {
            "description": "Method not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "PartnerIntakeBearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CampaignKitRequest"
              }
            }
          }
        }
      }
    },
    "/api/partners/log-event": {
      "post": {
        "summary": "Log partner event",
        "description": "Logs or stubs a partner event such as GPT review, onboarding action, resource recommendation, or action test result. Do not send raw PII in event metadata.",
        "operationId": "logPartnerEvent",
        "tags": [
          "Partner Intake OS"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogEventResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "405": {
            "description": "Method not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "PartnerIntakeBearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogEventRequest"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "PartnerIntakeBearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API key",
        "description": "Use the Partner Intake OS Action token. Configure the Custom GPT Action auth as API key/Bearer and store the same value in Vercel as PARTNER_INTAKE_ACTION_TOKEN."
      }
    },
    "schemas": {
      "ApiError": {
        "type": "object",
        "required": [
          "ok",
          "error"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string",
                "example": "UNAUTHORIZED"
              },
              "message": {
                "type": "string",
                "example": "Bearer token is missing or invalid."
              },
              "details": {
                "type": "object",
                "additionalProperties": true
              },
              "request_id": {
                "type": "string",
                "example": "req_lx4r9k2p"
              }
            }
          }
        }
      },
      "PartnerIntake": {
        "type": "object",
        "description": "Normalized or manual partner intake payload. Avoid sending borrower PII or sensitive documents.",
        "properties": {
          "first_name": {
            "type": "string",
            "example": "Dana"
          },
          "last_name": {
            "type": "string",
            "example": "Cole"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "dana@example.com"
          },
          "company": {
            "type": "string",
            "example": "Cole Advisory"
          },
          "website": {
            "type": "string",
            "example": "https://example.com"
          },
          "partner_type_claimed": {
            "type": "string",
            "example": "CPA/bookkeeper"
          },
          "audience": {
            "type": "string",
            "example": "contractors and local service businesses"
          },
          "industry": {
            "type": "string",
            "example": "Accounting"
          },
          "location": {
            "type": "string",
            "example": "Virginia"
          },
          "funding_experience": {
            "type": "string",
            "example": "Clients frequently ask about working capital options."
          },
          "current_tools": {
            "type": "string",
            "example": "HubSpot, Google Sheets, QuickBooks"
          },
          "traffic_or_network_size": {
            "type": "string",
            "example": "250 SMB clients and referral network"
          },
          "referral_volume_estimate": {
            "type": "string",
            "example": "3-5 monthly"
          },
          "desired_partner_role": {
            "type": "string",
            "example": "Referral partner"
          },
          "notes": {
            "type": "string",
            "example": "Interested in a compliant client resource and simple referral workflow."
          },
          "source": {
            "type": "string",
            "example": "manual_gpt_review"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-06T12:00:00Z"
          }
        },
        "additionalProperties": true
      },
      "ClassifyPartnerRequest": {
        "type": "object",
        "required": [
          "intake"
        ],
        "properties": {
          "intake": {
            "$ref": "#/components/schemas/PartnerIntake"
          },
          "context": {
            "type": "string",
            "example": "manual_review"
          },
          "request_options": {
            "type": "object",
            "properties": {
              "include_reasoning_summary": {
                "type": "boolean",
                "example": true
              },
              "include_dashboard_card": {
                "type": "boolean",
                "example": true
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "ClassifyPartnerResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "request_id": {
            "type": "string",
            "example": "req_lx4r9k2p"
          },
          "profile": {
            "type": "object",
            "properties": {
              "partner_id": {
                "type": "string",
                "example": "ptr_demo_7f42"
              },
              "display_name": {
                "type": "string",
                "example": "Dana Cole"
              },
              "company": {
                "type": "string",
                "example": "Cole Advisory"
              },
              "partner_type": {
                "type": "string",
                "example": "cpa_bookkeeper"
              },
              "partner_tier": {
                "type": "string",
                "example": "tier_2"
              },
              "onboarding_path": {
                "type": "string",
                "example": "standard_affiliate_partner"
              },
              "risk_level": {
                "type": "string",
                "example": "low"
              },
              "status": {
                "type": "string",
                "example": "manual_review"
              }
            },
            "additionalProperties": true
          },
          "scorecard": {
            "type": "object",
            "properties": {
              "overall_score": {
                "type": "number",
                "example": 78
              },
              "audience_fit_score": {
                "type": "number",
                "example": 85
              },
              "trust_score": {
                "type": "number",
                "example": 80
              },
              "revenue_potential_score": {
                "type": "number",
                "example": 72
              },
              "activation_speed_score": {
                "type": "number",
                "example": 70
              },
              "compliance_risk_score": {
                "type": "number",
                "example": 15
              },
              "tier_recommendation": {
                "type": "string",
                "example": "tier_2"
              },
              "reasoning_summary": {
                "type": "string",
                "example": "Strong SMB audience access and low compliance risk; needs standard onboarding before activation."
              },
              "manual_review_required": {
                "type": "boolean",
                "example": true
              }
            },
            "additionalProperties": true
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "manual_review_required": {
            "type": "boolean",
            "example": true
          },
          "next_action": {
            "type": "string",
            "example": "send_resource_pack_and_schedule_partner_fit_call"
          },
          "compliance_note": {
            "type": "string",
            "example": "Educational partner guidance only. No approval, funding, revenue, or commission outcome is guaranteed."
          }
        },
        "additionalProperties": true
      },
      "ResourceRecommendationRequest": {
        "type": "object",
        "properties": {
          "partner_type": {
            "type": "string",
            "example": "cpa_bookkeeper"
          },
          "audience": {
            "type": "string",
            "example": "contractors and local service businesses"
          },
          "partner_tier": {
            "type": "string",
            "example": "tier_2"
          },
          "profile": {
            "$ref": "#/components/schemas/PartnerIntake"
          }
        },
        "additionalProperties": true
      },
      "ResourceRecommendationResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "request_id": {
            "type": "string",
            "example": "req_lx4r9k2p"
          },
          "recommended_resources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "example": [
              {
                "title": "Client Funding Readiness Checklist",
                "resource_type": "lead_magnet",
                "priority": "high",
                "reason": "Fits CPA/bookkeeper audience without making funding promises.",
                "cta": "Review funding readiness"
              }
            ]
          },
          "next_action": {
            "type": "string",
            "example": "send_partner_resource_pack"
          }
        },
        "additionalProperties": true
      },
      "OnboardingPlanRequest": {
        "type": "object",
        "properties": {
          "partner_id": {
            "type": "string",
            "example": "ptr_demo_7f42"
          },
          "partner_type": {
            "type": "string",
            "example": "funding_broker"
          },
          "partner_tier": {
            "type": "string",
            "example": "tier_2"
          },
          "onboarding_path": {
            "type": "string",
            "example": "standard_affiliate_partner"
          },
          "profile": {
            "$ref": "#/components/schemas/PartnerIntake"
          }
        },
        "additionalProperties": true
      },
      "OnboardingPlanResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "request_id": {
            "type": "string",
            "example": "req_lx4r9k2p"
          },
          "partner_id": {
            "type": "string",
            "example": "ptr_demo_7f42"
          },
          "first_24_hours": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Confirm partner profile",
              "Send starter resource pack",
              "Create review task"
            ]
          },
          "first_7_days": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Complete onboarding call",
              "Assign campaign kit",
              "Generate tracking link"
            ]
          },
          "first_30_days": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Review first referrals",
              "Update CRM notes",
              "Decide activation tier"
            ]
          },
          "required_assets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Partner intro script",
              "Funding readiness checklist",
              "Tracking link"
            ]
          },
          "owner": {
            "type": "string",
            "example": "partner_ops"
          },
          "next_action": {
            "type": "string",
            "example": "schedule_partner_onboarding_call"
          }
        },
        "additionalProperties": true
      },
      "CampaignKitRequest": {
        "type": "object",
        "properties": {
          "partner_id": {
            "type": "string",
            "example": "ptr_demo_7f42"
          },
          "partner_type": {
            "type": "string",
            "example": "creator_affiliate"
          },
          "audience": {
            "type": "string",
            "example": "ecommerce sellers"
          },
          "offer": {
            "type": "string",
            "example": "Funding readiness review"
          },
          "channel_preference": {
            "type": "string",
            "example": "email and short-form social"
          }
        },
        "additionalProperties": true
      },
      "CampaignKitResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "request_id": {
            "type": "string",
            "example": "req_lx4r9k2p"
          },
          "campaign_concept": {
            "type": "string",
            "example": "Cash Flow Gap Checkup"
          },
          "cta": {
            "type": "string",
            "example": "Check funding readiness"
          },
          "suggested_channels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "email",
              "LinkedIn",
              "short-form video"
            ]
          },
          "tracking_notes": {
            "type": "string",
            "example": "Use partner_id and campaign_id in UTMs. Do not include sensitive lead data in URLs."
          },
          "copy_angle": {
            "type": "string",
            "example": "Help business owners spot funding-readiness gaps before they need cash yesterday."
          }
        },
        "additionalProperties": true
      },
      "LogEventRequest": {
        "type": "object",
        "required": [
          "event_type",
          "summary"
        ],
        "properties": {
          "partner_id": {
            "type": "string",
            "example": "ptr_demo_7f42"
          },
          "event_type": {
            "type": "string",
            "example": "gpt_action_test"
          },
          "summary": {
            "type": "string",
            "example": "GPT Action live test completed successfully."
          },
          "next_action": {
            "type": "string",
            "example": "review_response_fixture"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      "LogEventResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "request_id": {
            "type": "string",
            "example": "req_lx4r9k2p"
          },
          "event_id": {
            "type": "string",
            "example": "evt_demo_8d91"
          },
          "logged": {
            "type": "boolean",
            "example": false
          },
          "storage": {
            "type": "string",
            "example": "mock"
          },
          "message": {
            "type": "string",
            "example": "Event accepted for mock logging. No production CRM write was performed."
          }
        },
        "additionalProperties": true
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "partner-intake-os"
          },
          "environment": {
            "type": "string",
            "example": "production"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-06T12:00:00Z"
          },
          "version": {
            "type": "string",
            "example": "0.1.0"
          }
        },
        "additionalProperties": true
      }
    }
  }
}